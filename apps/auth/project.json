{
	"name": "auth",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/auth/src",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "webpack-cli build",
				"env": {
					"NODE_ENV": "production"
				},
				"cwd": "apps/auth",
				"assets": [
					"apps/auth/src/assets",
					{
						"glob": "**/*.proto",
						"input": "libs/api/shared/utils/src/lib/proto/auth",
						"output": "proto"
					}
				]
			},
			"configurations": {
				"development": {
					"env": {
						"NODE_ENV": "development"
					}
				}
			}
		},
		"prune-lockfile": {
			"dependsOn": ["build"],
			"cache": true,
			"executor": "@nx/js:prune-lockfile",
			"outputs": [
				"{workspaceRoot}/dist/apps/auth/package.json",
				"{workspaceRoot}/dist/apps/auth/yarn.lock"
			],
			"options": {
				"buildTarget": "build"
			}
		},
		"copy-workspace-modules": {
			"dependsOn": ["build"],
			"cache": true,
			"outputs": ["{workspaceRoot}/dist/apps/auth/workspace_modules"],
			"executor": "@nx/js:copy-workspace-modules",
			"options": {
				"buildTarget": "build"
			}
		},
		"prune": {
			"dependsOn": ["prune-lockfile", "copy-workspace-modules"],
			"executor": "nx:noop"
		},
		"serve": {
			"continuous": true,
			"executor": "@nx/js:node",
			"defaultConfiguration": "development",
			"dependsOn": ["build"],
			"options": {
				"buildTarget": "auth:build",
				"runBuildTargetDependencies": false
			},
			"configurations": {
				"development": {
					"buildTarget": "auth:build:development"
				},
				"production": {
					"buildTarget": "auth:build:production"
				}
			}
		},
		"db-push": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npx prisma db push --schema=libs/api/auth/data-access/src/lib/prisma/schema.prisma --config=libs/api/auth/data-access/src/lib/prisma/prisma.config.ts"
			}
		},
		"prisma-generate": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npx prisma generate --schema=libs/api/auth/data-access/src/lib/prisma/schema.prisma"
			}
		}
	},
	"tags": []
}
