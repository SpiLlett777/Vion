{
	"compileOnSave": false,
	"compilerOptions": {
		"rootDir": ".",
		"sourceMap": true,
		"declaration": false,
		"moduleResolution": "node",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"importHelpers": true,
		"strictPropertyInitialization": false,
		"target": "es2015",
		"module": "esnext",
		"lib": ["es2020", "dom"],
		"skipLibCheck": true,
		"skipDefaultLibCheck": true,
		"paths": {
			// Auth
			"@vion/auth/data-access": ["./libs/api/auth/data-access/src/index.ts"],
			"@vion/auth/feature": ["./libs/api/auth/feature/src/index.ts"],

			// Backend Shared
			"@vion/api/shared/utils": ["./libs/api/shared/utils/src/index.ts"],
			"@vion/api/contracts": ["./libs/api/contracts/src/index.ts"],

			// Global Shared
			"@vion/shared/contracts": ["./libs/shared/contracts/src/index.ts"],
			"@vion/shared/dto": ["./libs/shared/dto/src/index.ts"]
		}
	},
	"exclude": ["node_modules", "tmp"]
}
